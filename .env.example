# ABR Pipeline — environment configuration
# Usage: copy this file to `.env` and fill in real values.
# .env is gitignored — NEVER commit real credentials.

# ============================================================
# API KEYS  (social search providers)
# ============================================================
BRAVE_API_KEY=BSAh5c6r_QHMkvH-K4zo2EcvjldXgF2
BING_API_KEY=your_key_here

# Optional: Anthropic API for LLM-generated outreach messages
ANTHROPIC_API_KEY=

# Optional: Telegram notification when run.py finishes
# Bot token from @BotFather, chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ============================================================
# PATHS
# ============================================================
OUTPUT_DIR=./output
LOG_DIR=./logs
INPUT_DIR=./abr-data

# Per-stage filenames (under OUTPUT_DIR)
PARSED_CSV=filtered_businesses.csv
NO_WEBSITE_CSV=no_website.csv
HAS_SOCIAL_CSV=has_social.csv
OUTREACH_CSV=outreach_ready.csv


# ============================================================
# FILTERS
# ============================================================
# Comma-separated Australian state codes to keep.
# Valid: NSW,VIC,QLD,WA,SA,TAS,ACT,NT
STATES=NSW,VIC,QLD

# Comma-separated industry keywords matched against entity name + ANZSIC description.
# Used to narrow to service-business ICP (Empirra target segments).
KEYWORDS=plumbing,electrical,cafe,salon,dental,mechanic,cleaning,landscaping,roofing,painting

# Keep only ACT (active) ABNs
ONLY_ACTIVE_ABN=true

# Require GST registration (proxy for trading business)
REQUIRE_GST=true

# Comma-separated ABR entity type codes (PRV, PUB, IND, DTT, FPT, ...)
ENTITY_TYPES=PRV,PUB,IND


# ============================================================
# DNS CHECK  (find businesses WITHOUT a website)
# ============================================================
# Max concurrent DNS lookups (asyncio.Semaphore)
DNS_CONCURRENCY=100

# Per-domain timeout in seconds
DNS_TIMEOUT=3.0

# DNS-over-HTTPS endpoint
DOH_ENDPOINT=https://cloudflare-dns.com/dns-query

# TLDs to try for each entity name, comma-separated, in order
DNS_TLDS=.com.au,.com,.net.au


# ============================================================
# SOCIAL SEARCH  (Facebook + Instagram lookup)
# ============================================================
# Delay between social search requests, in milliseconds (rate-limit politeness)
SOCIAL_DELAY_MS=400

# Max concurrent social searches
SOCIAL_CONCURRENCY=5

# Per-request timeout (seconds)
SOCIAL_TIMEOUT=10.0

# Preferred search provider: brave | bing | duckduckgo
SOCIAL_PROVIDER=brave


# ============================================================
# MESSAGE GENERATION  (Claude API)
# ============================================================
MESSAGE_MODEL=claude-haiku-4-5-20251001

# How many distinct outreach variants per lead (columns message_v1..message_vN)
MESSAGE_VARIANTS=2

# Max tokens per Claude response
MESSAGE_MAX_TOKENS=600

# Max concurrent Claude API calls
MESSAGE_CONCURRENCY=8


# ============================================================
# PIPELINE  (global)
# ============================================================
# Stop after N parsed records (0 = process everything). Useful for dev/debug.
PIPELINE_LIMIT=0

# Chunk size for pandas CSV operations
PIPELINE_CHUNK_SIZE=5000

# Retry attempts for transient API failures (tenacity)
RETRY_ATTEMPTS=3
RETRY_BACKOFF_MIN=1
RETRY_BACKOFF_MAX=8

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
